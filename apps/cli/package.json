{
	"name": "@launchkey/cli",
	"version": "0.2.0",
	"description": "CLI for LaunchKey",
	"private": false,
	"type": "module",
	"bin": {
		"launchkey": "./dist/bin.js"
	},
	"files": [
		"dist/bin.js",
		"LICENSE",
		"README.md"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/endalk200/launchkey.git",
		"directory": "apps/cli"
	},
	"license": "MIT",
	"engines": {
		"node": ">=22.12.0"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "bun run ../../scripts/build-cli.ts",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"format": "biome format --write package.json tsconfig.json src",
		"format:check": "biome format package.json tsconfig.json src",
		"lint": "biome check package.json tsconfig.json src",
		"lint:fix": "biome check --fix package.json tsconfig.json src",
		"test": "vitest run src --passWithNoTests"
	},
	"devDependencies": {
		"@effect/opentelemetry": "4.0.0-beta.98",
		"@effect/platform-node": "4.0.0-beta.98",
		"@effect/vitest": "4.0.0-beta.98",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/api-logs": "^0.220.0",
		"@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
		"@opentelemetry/resources": "^2.7.1",
		"@opentelemetry/sdk-logs": "^0.220.0",
		"@opentelemetry/sdk-trace-base": "^2.9.0",
		"@opentelemetry/sdk-trace-node": "^2.9.0",
		"@opentelemetry/semantic-conventions": "^1.43.0",
		"@launchkey/config": "workspace:*",
		"@launchkey/typescript-config": "workspace:*",
		"@types/node": "^26.1.1",
		"effect": "4.0.0-beta.98",
		"typescript": "7.0.2",
		"vitest": "^4.1.10"
	}
}
